# Server
PORT=3002
NODE_ENV=development

# Supabase (same instance as KPI system)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
ALLOWED_EMAIL_DOMAIN=creativepan.com.eg

# JWT
JWT_SECRET=your-qa-jwt-secret
JWT_EXPIRES_IN=7d

# KPI System Integration (POST score on audit approval)
KPI_API_URL=https://vasko-kpi-production.up.railway.app
KPI_API_KEY=your-service-to-service-key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=info
